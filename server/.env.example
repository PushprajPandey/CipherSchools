# ─── Server Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values

# MongoDB connection string (Atlas recommended)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cipher_sql_studio?retryWrites=true&w=majority

# PostgreSQL connection string (sandbox for running student queries)
POSTGRES_URI=postgresql://<username>:<password>@<host>:5432/cipher_sql_sandbox

# Google Gemini API key (for LLM-powered hints)
GEMINI_API_KEY=your_gemini_api_key_here

# Server port
PORT=5000

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
